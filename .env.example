# Database
DATABASE_URL=postgresql://user:password@localhost:5432/auth_gateway

# JWT Secret (generate a long random string)
JWT_SECRET=your-very-long-secret-key-change-this

# Allowed email domain (only emails from this domain can register)
ALLOWED_EMAIL_DOMAIN=igs.com.tw

# Initial admin account (created on first run)
ADMIN_EMAIL=admin@igs.com.tw
ADMIN_PASSWORD=changeme123

# Server
PORT=4000

# Allowed app origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://meta-ads-reviewer-production-0cd5.up.railway.app,https://apple-ads-manager-production.up.railway.app,https://google-ads-manager-production.up.railway.app

# Cookie domain (leave empty for development)
COOKIE_DOMAIN=
